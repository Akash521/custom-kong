version: "3.9"

x-kong-config: &kong-env
  KONG_DATABASE: postgres
  KONG_PG_DATABASE: kong
  KONG_PG_HOST: db
  KONG_PG_USER: kong
  KONG_PG_PASSWORD_FILE: /run/secrets/kong_postgres_password

  # ✅ PLUGIN CONFIGURATION
  KONG_PLUGINS: bundled,oidc
  
  # ✅ FIXED LUA PATH - This is critical for plugin loading
  KONG_LUA_PACKAGE_PATH: "/usr/local/kong/plugins/?.lua;/usr/local/kong/plugins/?/init.lua;/tmp/?.lua;/tmp/?/init.lua;;"
  
  # ✅ ADD LUA C PATH if needed for native modules
  KONG_LUA_CPATH: "/usr/local/kong/lib/?.so;;"

volumes:
  kong_data:
  kong_prefix_vol:
    driver_opts:
      type: tmpfs
      device: tmpfs
  kong_tmp_vol:
    driver_opts:
      type: tmpfs
      device: tmpfs

networks:
  kong-net:
    driver: bridge

services:

  db:
    image: postgres:18.2
    container_name: kong-postgres
    environment:
      POSTGRES_DB: kong
      POSTGRES_USER: kong
      POSTGRES_PASSWORD_FILE: /run/secrets/kong_postgres_password
    secrets:
      - kong_postgres_password
    volumes:
      - kong_data:/var/lib/postgresql  # ✅ FIXED: Added /data
    networks:
      - kong-net
    restart: always
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U kong -d kong"]
      interval: 10s
      timeout: 5s
      retries: 5

  kong-migrations:
    image: kong:3.6
    command: kong migrations bootstrap
    depends_on:
      db:
        condition: service_healthy
    environment:
      <<: *kong-env
    secrets:
      - kong_postgres_password
    networks:
      - kong-net
    restart: on-failure
    volumes:
      # ✅ Mount plugins for migrations too (important!)
      - ./kong-custom/plugins:/usr/local/kong/plugins
      - ./kong-custom/deps:/usr/local/kong/lib

  kong-migrations-up:
    image: kong:3.6
    command: kong migrations up && kong migrations finish
    depends_on:
      db:
        condition: service_healthy
    environment:
      <<: *kong-env
    secrets:
      - kong_postgres_password
    networks:
      - kong-net
    restart: on-failure
    volumes:
      # ✅ Mount plugins for migrations too
      - ./kong-custom/plugins:/usr/local/kong/plugins
      - ./kong-custom/deps:/usr/local/kong/lib

  kong:
    image: kong:3.6
    container_name: kong-gateway
    user: kong
    depends_on:
      db:
        condition: service_healthy
      kong-migrations:
        condition: service_completed_successfully
      kong-migrations-up:
        condition: service_completed_successfully

    environment:
      <<: *kong-env
      KONG_PROXY_LISTEN: 0.0.0.0:8000
      KONG_ADMIN_LISTEN: 0.0.0.0:8001
      KONG_ADMIN_GUI_LISTEN: 0.0.0.0:8002
      KONG_ADMIN_GUI_URL: http://localhost:8002  # ✅ ADDED for Kong Manager

      KONG_ADMIN_ACCESS_LOG: /dev/stdout
      KONG_ADMIN_ERROR_LOG: /dev/stderr
      KONG_PROXY_ACCESS_LOG: /dev/stdout
      KONG_PROXY_ERROR_LOG: /dev/stderr

      KONG_PREFIX: /var/run/kong
      
      # ✅ ADD DEBUG LOGGING to see plugin loading
      KONG_LOG_LEVEL: debug  # Change to info after testing

    secrets:
      - kong_postgres_password

    networks:
      - kong-net

    ports:
      - "8000:8000"
      - "8443:8443"
      - "8001:8001"
      - "8444:8444"
      - "8002:8002"

    restart: always
    # ✅ REMOVE read_only: true temporarily for debugging
    # read_only: true

    volumes:
      - kong_prefix_vol:/var/run/kong
      - kong_tmp_vol:/tmp

      # ✅ CRITICAL: Mount to the correct location Kong expects
      - ./kong-custom/plugins:/usr/local/kong/plugins
      - ./kong-custom/deps:/usr/local/kong/lib
      
      # ✅ Keep this as fallback if needed
      - ./kong-custom/plugins:/tmp/kong/plugins

    healthcheck:
      test: ["CMD", "kong", "health"]
      interval: 10s
      timeout: 10s
      retries: 10

    # ✅ Temporarily remove security_opt for debugging
    # security_opt:
    #   - no-new-privileges

secrets:
  kong_postgres_password:
    file: ./POSTGRES_PASSWORD
